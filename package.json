    "e2e:electrobun:skills-live": "node scripts/e2e-electrobun-agent-skills-live.js"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.54.2",
    "@mariozechner/pi-coding-agent": "latest",
    "electrobun": "^1.15.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "agent-browser": "^0.13.0",
    "lit": "^3.3.2",
    "typescript": "^5.7.3"
  }
}
