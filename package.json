{
  "name": "lilt-o",
  "version": "0.1.0",
  "private": true,
  "description": "Lilt-o desktop shell with Pi SDK bridge",
  "scripts": {
    "prebuild": "node scripts/sync-skill-creator.js",
    "build": "electrobun build",
