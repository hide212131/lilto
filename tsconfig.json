{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "electrobun.config.ts"],
  "exclude": [
    "node_modules",
    "src/preload.ts",
    "src/main/index.ts",
    "src/main/ipc.ts"
  ]
}
